---
import { z } from "astro/zod";
import Stripe from "stripe";
import { drizzle } from "drizzle-orm/d1";
import * as dbSchema from "../../db/schema";
import { eq } from "drizzle-orm";
import { createAuth } from "../../lib/auth";
import { Button } from "@components/ui/button";
import { Input } from "@components/ui/input";
import { Label } from "@components/ui/label";
import { Card, CardContent } from "@components/ui/card";
import "../../styles/global.css";
import { env } from "cloudflare:workers";

export const prerender = false;

// ── Auth check ───────────────────────────────────────────────────────────────
const auth = createAuth(env);
const { user: currentUser } = Astro.locals;
const isLoggedIn = !!currentUser;

let errors: Record<string, string[]> = {};
let submissionError = "";

// ── Zod schema ───────────────────────────────────────────────────────────────
const formSchema = z.object({
  name: z.string().min(2, "Name is required"),
  email: z.email("Invalid email address").optional(),
  password: z
    .string()
    .min(8, "Password must be at least 8 characters")
    .optional(),
  age: z.coerce
    .number()
    .min(14, "Must be at least 14")
    .max(100, "Must be 100 or under"),
  unitSystem: z.enum(["metric", "imperial"]),
  weight: z.coerce.number().min(1, "Weight is required"),
  height: z.coerce.number().min(1, "Height is required"),
  frequency: z.coerce
    .number()
    .min(2, "Minimum 2 days")
    .max(6, "Maximum 6 days"),
  trainingDays: z.string().min(1, "Please select your training days"),
  equipment: z.enum(["Gym", "Home", "Other"]),
  equipmentDetails: z.string().optional(),
  failureExp: z.string().min(1, "Please describe your experience"),
  goals: z.string().min(10, "Please provide more detail about your goals"),
  weakPoints: z.string().optional(),
  injuries: z.string().optional(),
  likedExercises: z.string().optional(),
  dislikedExercises: z.string().optional(),
});

// ── Form handler ─────────────────────────────────────────────────────────────
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const data = Object.fromEntries(formData.entries());
    const validated = formSchema.safeParse(data);

    if (!validated.success) {
      errors = validated.error.flatten().fieldErrors as any;
    } else {
      // Extra validations
      if (!isLoggedIn && !validated.data.email) {
        errors.email = ["Email is required to create your account."];
        throw new Error("Email required");
      }
      if (!isLoggedIn && !validated.data.password) {
        errors.password = ["Password is required to create your account."];
        throw new Error("Password required");
      }
      if (
        validated.data.equipment === "Other" &&
        !validated.data.equipmentDetails?.trim()
      ) {
        errors.equipmentDetails = ["Please describe your equipment."];
        throw new Error("Equipment details required");
      }

      const db = drizzle(env.DB, { schema: dbSchema });

      // ── Resolve user ─────────────────────────────────────────────────────
      let userId: string;

      if (isLoggedIn) {
        userId = currentUser!.id;
      } else {
        // Check if user already exists
        let dbUser = await db.query.user.findFirst({
          where: (users, { eq }) => eq(users.email, validated.data.email!),
        });

        if (dbUser) {
          // Existing user not logged in — they need to log in first
          errors.email = [
            "An account with this email already exists. Please log in first.",
          ];
          throw new Error("Account exists");
        }

        // Create new account
        const result = await auth.api.signUpEmail({
          body: {
            email: validated.data.email!,
            password: validated.data.password!,
            name: validated.data.name,
          },
          asResponse: false,
        });
        if (!result.user) throw new Error("Failed to create account");
        userId = result.user.id;
      }

      // ── Unit conversion (always store as metric) ─────────────────────────
      let weight = validated.data.weight;
      let height = validated.data.height;
      if (validated.data.unitSystem === "imperial") {
        weight = Math.round(weight * 0.453592); // lbs → kg
        height = Math.round(height * 2.54); // in → cm
      }

      const requestId = crypto.randomUUID();

      // ── Insert plan request ──────────────────────────────────────────────
      await db.insert(dbSchema.planRequests).values({
        id: requestId,
        userId: userId,
        name: validated.data.name,
        age: validated.data.age,
        weight: weight,
        height: height,
        trainingFrequency: validated.data.frequency,
        trainingDays: validated.data.trainingDays,
        equipment: validated.data.equipment,
        equipmentDetails:
          validated.data.equipment === "Other"
            ? validated.data.equipmentDetails || ""
            : null,
        failureExp: validated.data.failureExp,
        goals: validated.data.goals,
        injuries: validated.data.injuries || "",
        weakPoints: validated.data.weakPoints || "",
        likedExercises: validated.data.likedExercises || "",
        dislikedExercises: validated.data.dislikedExercises || "",
        status: "pending_payment",
        createdAt: new Date(),
        updatedAt: new Date(),
      });

      // ── Stripe checkout ──────────────────────────────────────────────────
      const stripe = new Stripe(env.STRIPE_SECRET_KEY, {
        apiVersion: "2024-04-10" as any,
      });

      const siteUrl = Astro.url.origin;

      const stripeSession = await stripe.checkout.sessions.create({
        payment_method_types: ["card"],
        line_items: [
          {
            price_data: {
              currency: "eur",
              product_data: {
                name: "Custom Hypertrophy Plan",
                description: "Hand-crafted 72-96hr turnaround",
              },
              unit_amount: 3000,
            },
            quantity: 1,
          },
        ],
        mode: "payment",
        success_url: `${siteUrl}/dashboard?session_id={CHECKOUT_SESSION_ID}`,
        cancel_url: `${siteUrl}/custom-plans/apply`,
        customer_email: isLoggedIn ? currentUser!.email : validated.data.email!,
        metadata: {
          requestId: requestId,
        },
      });

      if (stripeSession.url) {
        await db
          .update(dbSchema.planRequests)
          .set({ stripeSessionId: stripeSession.id, updatedAt: new Date() })
          .where(eq(dbSchema.planRequests.id, requestId));
        return Astro.redirect(stripeSession.url);
      }
    }
  } catch (err: any) {
    console.error("APPLY FORM ERROR:", err?.message || err, err?.stack || "");
    if (Object.keys(errors).length === 0) {
      submissionError = `An unexpected error occurred: ${err?.message || "Unknown error"}`;
    }
  }
}
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Apply for Custom Plan — BuffBook</title>
    <script is:inline>
      document.documentElement.dataset.theme = 'dark';
    </script>
  </head>
  <body
    class="bg-background text-foreground font-sans antialiased min-h-screen relative flex items-center justify-center p-6 sm:p-12"
  >
    <div
      class="pointer-events-none fixed inset-0 -z-10"
      style="background: radial-gradient(ellipse 600px 400px at 80% 0%, hsl(var(--primary) / 0.07), transparent), radial-gradient(ellipse 400px 300px at 10% 100%, hsl(var(--primary) / 0.04), transparent);"
    >
    </div>

    <div class="w-full max-w-3xl pb-16">
      <div class="text-center mb-10">
        <h1
          class="text-4xl sm:text-5xl font-black tracking-tight text-primary mb-2"
        >
          Custom Plan Assessment
        </h1>
        <p class="text-muted-foreground text-lg">
          Fill out the form, pay, and receive your hand-crafted hypertrophy plan
          within 72-96 hours.
        </p>
      </div>

      {
        submissionError && (
          <div class="bg-destructive/10 border border-destructive/30 text-destructive rounded-lg p-4 text-center mb-8 font-medium">
            {submissionError}
          </div>
        )
      }

      {
        isLoggedIn && currentUser && (
          <div class="flex flex-col sm:flex-row items-center justify-between bg-primary/10 border border-primary/20 rounded-lg p-3 px-5 mb-8 text-sm">
            <div class="flex items-center gap-3 mb-2 sm:mb-0">
              <div class="w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold">
                {currentUser.name?.charAt(0)?.toUpperCase() || "U"}
              </div>
              <div>
                <span class="font-bold text-foreground">
                  {currentUser.name}
                </span>
                <span class="text-muted-foreground ml-1">
                  ({currentUser.email})
                </span>
              </div>
            </div>
            <button
              id="apply-signout-btn"
              type="button"
              class="text-muted-foreground hover:text-primary transition-colors underline underline-offset-2"
            >
              Not you? Sign out
            </button>
          </div>
        )
      }

      <Card className="bg-card/50 backdrop-blur-xl border-border shadow-2xl">
        <CardContent className="p-6 sm:p-10">
          <form method="POST" class="space-y-12">
            {
              !isLoggedIn && (
                <fieldset class="space-y-6">
                  <legend class="text-2xl font-black tracking-tight text-foreground border-b border-border pb-3 w-full">
                    Create Your Account
                  </legend>
                  <p class="text-sm text-muted-foreground -mt-4 mb-4">
                    You'll use these credentials to access your plan after
                    purchase.
                  </p>
                  <div class="space-y-3">
                    <Label htmlFor="name">Full Name</Label>
                    <Input
                      type="text"
                      id="name"
                      name="name"
                      required
                      autoComplete="name"
                      placeholder="John Doe"
                    />
                    {errors.name && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.name[0]}
                      </span>
                    )}
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="space-y-3">
                      <Label htmlFor="email">Email Address</Label>
                      <Input
                        type="email"
                        id="email"
                        name="email"
                        required
                        autoComplete="email"
                        placeholder="john@example.com"
                      />
                      {errors.email && (
                        <span class="text-sm text-destructive font-medium block mt-1">
                          {errors.email[0]}
                        </span>
                      )}
                    </div>
                    <div class="space-y-3">
                      <Label htmlFor="password">Password</Label>
                      <Input
                        type="password"
                        id="password"
                        name="password"
                        required
                        autoComplete="new-password"
                        placeholder="Min. 8 characters"
                        minLength={8}
                      />
                      {errors.password && (
                        <span class="text-sm text-destructive font-medium block mt-1">
                          {errors.password[0]}
                        </span>
                      )}
                    </div>
                  </div>
                </fieldset>
              )
            }

            {
              isLoggedIn && currentUser && (
                <input
                  type="hidden"
                  name="name"
                  value={currentUser.name || ""}
                />
              )
            }

            <fieldset class="space-y-6">
              <legend
                class="text-2xl font-black tracking-tight text-foreground border-b border-border pb-3 w-full"
                >Body Metrics</legend
              >

              <div class="space-y-3">
                <Label>Unit System</Label>
                <div class="inline-flex bg-muted rounded-md p-1 unit-toggle">
                  <button
                    type="button"
                    data-unit="metric"
                    data-active="true"
                    class="px-4 py-2 rounded-sm text-sm font-medium transition-colors data-[active=true]:bg-background data-[active=true]:text-foreground data-[active=true]:shadow-sm text-muted-foreground hover:text-foreground"
                    >Metric (kg / cm)</button
                  >
                  <button
                    type="button"
                    data-unit="imperial"
                    data-active="false"
                    class="px-4 py-2 rounded-sm text-sm font-medium transition-colors data-[active=true]:bg-background data-[active=true]:text-foreground data-[active=true]:shadow-sm text-muted-foreground hover:text-foreground"
                    >Imperial (lbs / in)</button
                  >
                </div>
                <input
                  type="hidden"
                  name="unitSystem"
                  id="unitSystem"
                  value="metric"
                />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <div class="space-y-3">
                  <Label htmlFor="age">Age</Label>
                  <Input
                    type="number"
                    id="age"
                    name="age"
                    required
                    min="14"
                    max="100"
                    placeholder="25"
                  />
                  {
                    errors.age && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.age[0]}
                      </span>
                    )
                  }
                </div>
                <div class="space-y-3">
                  <Label htmlFor="weight" id="weight-label">Weight (kg)</Label>
                  <Input
                    type="number"
                    id="weight"
                    name="weight"
                    required
                    placeholder="80"
                    step="any"
                  />
                  {
                    errors.weight && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.weight[0]}
                      </span>
                    )
                  }
                </div>
                <div class="space-y-3">
                  <Label htmlFor="height" id="height-label">Height (cm)</Label>
                  <Input
                    type="number"
                    id="height"
                    name="height"
                    required
                    placeholder="180"
                    step="any"
                  />
                  {
                    errors.height && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.height[0]}
                      </span>
                    )
                  }
                </div>
              </div>
            </fieldset>

            <fieldset class="space-y-6">
              <legend
                class="text-2xl font-black tracking-tight text-foreground border-b border-border pb-3 w-full"
                >Training Setup</legend
              >

              <div class="space-y-3">
                <Label>Equipment</Label>
                <div class="flex flex-wrap gap-3">
                  <div class="relative group">
                    <input
                      type="radio"
                      name="equipment"
                      id="eq-gym"
                      value="Gym"
                      checked
                      class="peer sr-only"
                    />
                    <Label
                      htmlFor="eq-gym"
                      className="inline-flex items-center justify-center px-5 py-2.5 rounded-full border border-border bg-transparent text-sm font-medium text-muted-foreground cursor-pointer transition-colors hover:border-primary/50 hover:text-foreground peer-checked:border-primary peer-checked:bg-primary peer-checked:text-primary-foreground peer-checked:font-bold"
                      >Full Gym</Label
                    >
                  </div>
                  <div class="relative group">
                    <input
                      type="radio"
                      name="equipment"
                      id="eq-home"
                      value="Home"
                      class="peer sr-only"
                    />
                    <Label
                      htmlFor="eq-home"
                      className="inline-flex items-center justify-center px-5 py-2.5 rounded-full border border-border bg-transparent text-sm font-medium text-muted-foreground cursor-pointer transition-colors hover:border-primary/50 hover:text-foreground peer-checked:border-primary peer-checked:bg-primary peer-checked:text-primary-foreground peer-checked:font-bold"
                      >Home Setup</Label
                    >
                  </div>
                  <div class="relative group">
                    <input
                      type="radio"
                      name="equipment"
                      id="eq-other"
                      value="Other"
                      class="peer sr-only"
                    />
                    <Label
                      htmlFor="eq-other"
                      className="inline-flex items-center justify-center px-5 py-2.5 rounded-full border border-border bg-transparent text-sm font-medium text-muted-foreground cursor-pointer transition-colors hover:border-primary/50 hover:text-foreground peer-checked:border-primary peer-checked:bg-primary peer-checked:text-primary-foreground peer-checked:font-bold"
                      >Other</Label
                    >
                  </div>
                </div>
                <div
                  class="overflow-hidden max-h-0 opacity-0 transition-all duration-300 [&.visible]:max-h-32 [&.visible]:opacity-100 [&.visible]:mt-4"
                  id="equipment-details-wrap"
                >
                  <Input
                    type="text"
                    name="equipmentDetails"
                    id="equipmentDetails"
                    placeholder="e.g. dumbbells + pull-up bar + bench"
                  />
                  {
                    errors.equipmentDetails && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.equipmentDetails[0]}
                      </span>
                    )
                  }
                </div>
              </div>

              <div class="flex flex-col sm:flex-row gap-6 items-start">
                <div class="space-y-3 w-full sm:w-32">
                  <Label htmlFor="frequency">Days / Week</Label>
                  <Input
                    type="number"
                    id="frequency"
                    name="frequency"
                    required
                    min="2"
                    max="6"
                    placeholder="4"
                  />
                  {
                    errors.frequency && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.frequency[0]}
                      </span>
                    )
                  }
                </div>
                <div class="space-y-3 flex-1">
                  <Label>Training Days</Label>
                  <div
                    class="flex flex-wrap gap-2 overflow-hidden max-h-0 opacity-0 transition-all duration-300 [&.visible]:max-h-32 [&.visible]:opacity-100 mt-2"
                    id="day-picker"
                  >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Mon">Mon</button
                    >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Tue">Tue</button
                    >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Wed">Wed</button
                    >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Thu">Thu</button
                    >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Fri">Fri</button
                    >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Sat">Sat</button
                    >
                    <button
                      type="button"
                      class="day-btn w-12 h-10 border border-border bg-muted rounded-md text-xs font-bold text-muted-foreground transition-all hover:border-primary/50 hover:text-foreground [&.selected]:bg-primary [&.selected]:border-primary [&.selected]:text-primary-foreground [&.selected]:scale-105 [&.disabled]:opacity-30 [&.disabled]:cursor-not-allowed"
                      data-day="Sun">Sun</button
                    >
                  </div>
                  <div
                    class="overflow-hidden max-h-0 opacity-0 transition-all duration-300 [&.visible]:max-h-12 [&.visible]:opacity-100 text-xs text-muted-foreground mt-2"
                    id="day-picker-label"
                  >
                    <span id="day-count-text">Select your training days</span>
                  </div>
                  <input
                    type="hidden"
                    name="trainingDays"
                    id="trainingDays"
                    value=""
                  />
                  {
                    errors.trainingDays && (
                      <span class="text-sm text-destructive font-medium block mt-1">
                        {errors.trainingDays[0]}
                      </span>
                    )
                  }
                </div>
              </div>
            </fieldset>

            <fieldset class="space-y-6">
              <legend
                class="text-2xl font-black tracking-tight text-foreground border-b border-border pb-3 w-full"
                >Experience & Goals</legend
              >
              <div class="space-y-3">
                <Label htmlFor="failureExp"
                  >How accustomed are you to training to true failure?</Label
                >
                <textarea
                  id="failureExp"
                  name="failureExp"
                  required
                  class="flex min-h-[90px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
                  placeholder="Describe your experience with pushing sets to or near failure..."
                ></textarea>
                {
                  errors.failureExp && (
                    <span class="text-sm text-destructive font-medium block mt-1">
                      {errors.failureExp[0]}
                    </span>
                  )
                }
              </div>
              <div class="space-y-3">
                <Label htmlFor="goals">Primary Goals</Label>
                <textarea
                  id="goals"
                  name="goals"
                  required
                  class="flex min-h-[90px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
                  placeholder="What are you trying to achieve? (e.g. general hypertrophy, bringing up arms, etc.)"
                ></textarea>
                {
                  errors.goals && (
                    <span class="text-sm text-destructive font-medium block mt-1">
                      {errors.goals[0]}
                    </span>
                  )
                }
              </div>
              <div class="space-y-3">
                <Label htmlFor="weakPoints"
                  >Weak Points <span class="text-muted-foreground font-normal"
                    >(optional, leave empty if beginner)</span
                  ></Label
                >
                <Input
                  type="text"
                  id="weakPoints"
                  name="weakPoints"
                  placeholder="e.g. Calves, Side Delts"
                />
              </div>
            </fieldset>

            <fieldset class="space-y-6">
              <legend
                class="text-2xl font-black tracking-tight text-foreground border-b border-border pb-3 w-full"
                >Preferences & Medical</legend
              >
              <div class="space-y-3">
                <Label htmlFor="injuries"
                  >Injuries or Limitations <span
                    class="text-muted-foreground font-normal">(optional)</span
                  ></Label
                >
                <textarea
                  id="injuries"
                  name="injuries"
                  class="flex min-h-[90px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
                  placeholder="List any past or current injuries that affect your lifting..."
                ></textarea>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-3">
                  <Label htmlFor="likedExercises"
                    >Favorite Exercises <span
                      class="text-muted-foreground font-normal">(optional)</span
                    ></Label
                  >
                  <textarea
                    id="likedExercises"
                    name="likedExercises"
                    class="flex min-h-[90px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
                    placeholder="e.g. Barbell Squat, Pull-ups"></textarea>
                </div>
                <div class="space-y-3">
                  <Label htmlFor="dislikedExercises"
                    >Disliked Exercises <span
                      class="text-muted-foreground font-normal">(optional)</span
                    ></Label
                  >
                  <textarea
                    id="dislikedExercises"
                    name="dislikedExercises"
                    class="flex min-h-[90px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
                    placeholder="e.g. Conventional Deadlift"></textarea>
                </div>
              </div>
            </fieldset>

            <Button
              type="submit"
              size="lg"
              className="w-full h-14 text-xl font-bold mt-8 shadow-lg hover:shadow-xl hover:shadow-primary/20 transition-all"
            >
              Continue to Payment (€30)
            </Button>
          </form>
        </CardContent>
      </Card>

      {
        isLoggedIn && (
          <p class="text-center mt-6 text-sm text-muted-foreground">
            Already purchased?{" "}
            <a
              href="/dashboard"
              class="text-primary hover:underline font-semibold"
            >
              Go to your dashboard →
            </a>
          </p>
        )
      }
    </div>

    <script>
      import { authClient } from "../../lib/auth-client";
      
      const applySignoutBtn = document.getElementById("apply-signout-btn");
      if (applySignoutBtn) {
        applySignoutBtn.addEventListener("click", async () => {
          await authClient.signOut();
          window.location.href = "/custom-plans/apply";
        });
      }

      // ── Unit toggle ──────────────────────────────────────────────────────
      const unitBtns = document.querySelectorAll<HTMLButtonElement>(
        ".unit-toggle button",
      );
      const unitInput = document.getElementById(
        "unitSystem",
      ) as HTMLInputElement;
      const weightLabel = document.getElementById("weight-label")!;
      const heightLabel = document.getElementById("height-label")!;
      const weightInput = document.getElementById("weight") as HTMLInputElement;
      const heightInput = document.getElementById("height") as HTMLInputElement;

      unitBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const unit = btn.dataset.unit!;
          unitBtns.forEach((b) => b.setAttribute("data-active", "false"));
          btn.setAttribute("data-active", "true");
          unitInput.value = unit;

          if (unit === "metric") {
            weightLabel.textContent = "Weight (kg)";
            heightLabel.textContent = "Height (cm)";
            weightInput.placeholder = "80";
            heightInput.placeholder = "180";
          } else {
            weightLabel.textContent = "Weight (lbs)";
            heightLabel.textContent = "Height (in)";
            weightInput.placeholder = "176";
            heightInput.placeholder = "71";
          }
        });
      });

      // ── Equipment "Other" reveal ─────────────────────────────────────────
      const eqRadios = document.querySelectorAll<HTMLInputElement>(
        'input[name="equipment"]',
      );
      const eqDetailsWrap = document.getElementById("equipment-details-wrap")!;

      eqRadios.forEach((radio) => {
        radio.addEventListener("change", () => {
          if (radio.value === "Other" && radio.checked) {
            eqDetailsWrap.classList.add("visible");
          } else {
            eqDetailsWrap.classList.remove("visible");
          }
        });
      });

      // ── Day picker ───────────────────────────────────────────────────────
      const freqInput = document.getElementById(
        "frequency",
      ) as HTMLInputElement;
      const dayPicker = document.getElementById("day-picker")!;
      const dayPickerLabel = document.getElementById("day-picker-label")!;
      const dayCountText = document.getElementById("day-count-text")!;
      const dayBtns = dayPicker.querySelectorAll<HTMLButtonElement>(".day-btn");
      const trainingDaysInput = document.getElementById(
        "trainingDays",
      ) as HTMLInputElement;

      let selectedDays: string[] = [];
      let maxDays = 0;

      function updateDayPicker() {
        const val = parseInt(freqInput.value);
        if (isNaN(val) || val < 2 || val > 6) {
          dayPicker.classList.remove("visible");
          dayPickerLabel.classList.remove("visible");
          maxDays = 0;
          selectedDays = [];
          syncDays();
          return;
        }

        maxDays = val;
        dayPicker.classList.add("visible");
        dayPickerLabel.classList.add("visible");

        // If we already have more selected than the new max, trim
        while (selectedDays.length > maxDays) {
          const removed = selectedDays.pop()!;
          dayBtns.forEach((b) => {
            if (b.dataset.day === removed) b.classList.remove("selected");
          });
        }

        updateDayStates();
        syncDays();
      }

      function updateDayStates() {
        const atLimit = selectedDays.length >= maxDays;
        dayBtns.forEach((btn) => {
          const isSelected = selectedDays.includes(btn.dataset.day!);
          btn.classList.toggle("disabled", atLimit && !isSelected);
        });

        const remaining = maxDays - selectedDays.length;
        if (remaining > 0) {
          dayCountText.textContent = `Select ${remaining} more day${remaining > 1 ? "s" : ""}`;
        } else {
          dayCountText.textContent = `All ${maxDays} days selected ✓`;
        }
      }

      function syncDays() {
        const dayOrder = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
        selectedDays.sort((a, b) => dayOrder.indexOf(a) - dayOrder.indexOf(b));
        trainingDaysInput.value = selectedDays.join(",");
      }

      freqInput.addEventListener("input", updateDayPicker);
      freqInput.addEventListener("change", updateDayPicker);

      dayBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const day = btn.dataset.day!;
          const idx = selectedDays.indexOf(day);

          if (idx >= 0) {
            // Deselect
            selectedDays.splice(idx, 1);
            btn.classList.remove("selected");
          } else if (selectedDays.length < maxDays) {
            // Select
            selectedDays.push(day);
            btn.classList.add("selected");
          } else {
            // At limit — shake animation
            btn.style.animation = "none";
            btn.offsetHeight; // reflow
            btn.style.animation = "shake 0.3s ease";
          }

          updateDayStates();
          syncDays();
        });
      });

      // Init on page load (if frequency is pre-filled)
      updateDayPicker();
    </script>

    <style>
      @keyframes shake {
        0%,
        100% {
          transform: translateX(0);
        }
        20% {
          transform: translateX(-3px);
        }
        40% {
          transform: translateX(3px);
        }
        60% {
          transform: translateX(-2px);
        }
        80% {
          transform: translateX(2px);
        }
      }
    </style>
  </body>
</html>
