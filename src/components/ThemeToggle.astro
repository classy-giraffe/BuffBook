---
---

<button
  data-theme-toggle
  class="text-muted-foreground hover:text-foreground transition-colors p-2 rounded-md"
  aria-label="Toggle theme"
>
  <svg
    data-theme-icon-dark
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
  <svg
    data-theme-icon-light
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
</button>

<script is:inline>
  (() => {
    if (window.__bbThemeInit) return;
    window.__bbThemeInit = true;

    function updateAllIcons(theme) {
      document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
        const darkIcon = btn.querySelector("[data-theme-icon-dark]");
        const lightIcon = btn.querySelector("[data-theme-icon-light]");
        if (theme === "light") {
          darkIcon?.classList.remove("hidden");
          lightIcon?.classList.add("hidden");
        } else {
          lightIcon?.classList.remove("hidden");
          darkIcon?.classList.add("hidden");
        }
      });
    }

    updateAllIcons(document.documentElement.dataset.theme);

    document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const currentTheme = document.documentElement.dataset.theme;
        const newTheme = currentTheme === "light" ? "dark" : "light";
        document.documentElement.dataset.theme = newTheme;
        if (typeof localStorage !== "undefined") {
          localStorage.setItem("starlight-theme", newTheme);
        }
        updateAllIcons(newTheme);
      });
    });
  })();
</script>
