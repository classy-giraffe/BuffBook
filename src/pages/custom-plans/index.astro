---
import { Button } from "../../components/components/ui/button";
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
} from "../../components/components/ui/card";
import "../../styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Custom Gym Plans — BuffBook</title>
    <meta
      name="description"
      content="Get a handcrafted, science-based gym plan tailored exactly to your goals, body, and experience level."
    />
  </head>
  <body
    class="bg-background text-foreground font-sans antialiased relative min-h-screen flex flex-col"
  >
    <nav
      class="fixed top-0 left-0 right-0 z-50 flex h-16 items-center justify-between border-b bg-background/80 px-6 md:px-12 backdrop-blur-md"
    >
      <a
        href="/"
        class="flex items-center gap-2 font-bold tracking-tight text-xl text-primary hover:opacity-80 transition-opacity"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-6 w-6 fill-primary"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z"
          ></path>
        </svg>
        BuffBook
      </a>
      <a href="/">
        <Button size="sm" variant="outline" className="font-bold"
          >Back to Book</Button
        >
      </a>
    </nav>

    <main class="flex-1">
      <section
        class="relative flex min-h-[85vh] flex-col items-center justify-center overflow-hidden px-6 text-center pt-24 pb-16"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10"
          style="background: radial-gradient(ellipse 70% 60% at 50% 40%, hsl(var(--primary) / 0.07) 0%, transparent 70%);"
        >
        </div>

        <div
          class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary mb-6"
        >
          <div class="h-px w-8 bg-primary/50"></div>
          Personalized Programming
          <div class="h-px w-8 bg-primary/50"></div>
        </div>

        <h1
          class="max-w-4xl text-5xl sm:text-7xl font-black tracking-tighter leading-[0.95] text-foreground mb-6"
        >
          Hand-crafted <span class="text-primary">Just For You.</span>
        </h1>

        <p
          class="max-w-2xl text-lg sm:text-xl text-muted-foreground mb-10 leading-relaxed"
        >
          No AI. No cookie-cutter templates. You fill out a comprehensive
          assessment, and I personally build your ideal hypertrophy plan from
          scratch in 72-96 hours.
        </p>

        <a href="/custom-plans/apply">
          <Button
            size="lg"
            className="h-14 px-8 text-base font-bold shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-shadow"
          >
            Get Your Plan — 30 EUR
          </Button>
        </a>
      </section>

      <section
        class="max-w-5xl mx-auto px-6 pb-24 grid grid-cols-1 sm:grid-cols-3 gap-8"
      >
        <Card className="flex flex-col">
          <CardHeader>
            <CardTitle className="text-2xl font-black text-primary"
              >100% Custom</CardTitle
            >
          </CardHeader>
          <CardContent className="flex-1">
            <p class="text-muted-foreground text-sm leading-relaxed">
              Built completely from scratch based on your weak points, injuries,
              and available equipment.
            </p>
          </CardContent>
        </Card>
        <Card className="flex flex-col">
          <CardHeader>
            <CardTitle className="text-2xl font-black text-primary"
              >Science-Backed</CardTitle
            >
          </CardHeader>
          <CardContent className="flex-1">
            <p class="text-muted-foreground text-sm leading-relaxed">
              Uses the exact peer-reviewed principles outlined in the BuffBook.
            </p>
          </CardContent>
        </Card>
        <Card className="flex flex-col">
          <CardHeader>
            <CardTitle className="text-2xl font-black text-primary"
              >Complete Guide</CardTitle
            >
          </CardHeader>
          <CardContent className="flex-1">
            <p class="text-muted-foreground text-sm leading-relaxed">
              Delivered as a detailed PDF including warm-ups, progression
              schemes, and logging instructions.
            </p>
          </CardContent>
        </Card>
      </section>
    </main>
  </body>
</html>
