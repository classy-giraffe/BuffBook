---
import Topbar from "./Topbar.astro";

interface Props {
  title?: string;
  user?: any;
}

const { title = "Dashboard — BuffBook", user } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --gold: #f7c800;
        --bg: #080808;
        --bg-card: #111111;
        --border: #222222;
        --text: #e8e8e8;
        --text-muted: #888888;
        --radius: 8px;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: "Inter", sans-serif;
        margin: 0; padding: 0;
        position: relative;
        min-height: 100vh;
        z-index: 0;
      }
      
      /* Yellowish halo background */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background:
          radial-gradient(
            ellipse 70% 60% at 50% 40%,
            rgba(247, 200, 0, 0.07) 0%,
            transparent 70%
          ),
          radial-gradient(
            ellipse 40% 30% at 20% 80%,
            rgba(247, 200, 0, 0.04) 0%,
            transparent 60%
          );
        pointer-events: none;
        z-index: -1;
      }

      .container {
        max-width: 1000px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }
      h1 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      p.subtitle {
        color: var(--text-muted);
        margin-bottom: 2rem;
      }
      
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
      }
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .card-title {
        font-weight: 600;
        font-size: 1.1rem;
      }
      .badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        color: #000;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .card-date {
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .btn {
        background: var(--border);
        color: var(--text);
        border: none;
        padding: 0.6rem;
        border-radius: 4px;
        text-align: center;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: background 0.2s;
        cursor: pointer;
        display: inline-block;
      }
      .btn:hover { background: #333; }
      .btn-primary {
        background: var(--gold);
        color: #000;
      }
      .btn-primary:hover { background: #ffe033; }
      
      .empty-state {
        text-align: center;
        padding: 4rem;
        border: 1px dashed var(--border);
        border-radius: var(--radius);
        color: var(--text-muted);
      }
    </style>
  </head>
  <body>
    <Topbar user={user} />
    <slot />
  </body>
</html>
