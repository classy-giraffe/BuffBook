---
import { getAuth } from "../../lib/auth";
import { drizzle } from "drizzle-orm/d1";
import { env } from "cloudflare:workers";
import * as dbSchema from "../../db/schema";
import { eq, desc } from "drizzle-orm";

export const prerender = false;

const { session, user } = Astro.locals;

if (!user) {
  return Astro.redirect("/login");
}

const db = drizzle(env.DB, { schema: dbSchema });

// If returning from Stripe Checkout, verify the payment and update DB
const sessionId = Astro.url.searchParams.get("session_id");
if (sessionId) {
  try {
    const Stripe = (await import("stripe")).default;
    const stripe = new Stripe(env.STRIPE_SECRET_KEY, {
      apiVersion: "2024-04-10" as any,
    });
    const checkoutSession = await stripe.checkout.sessions.retrieve(sessionId);
    
    if (checkoutSession.payment_status === "paid" && checkoutSession.metadata?.requestId) {
      await db.update(dbSchema.planRequests)
        .set({ status: "paid", stripeSessionId: sessionId, updatedAt: new Date() })
        .where(eq(dbSchema.planRequests.id, checkoutSession.metadata.requestId));
    }
  } catch (err) {
    console.error("Stripe session verification error:", err);
  }
  // Redirect to clean URL (remove query param) so refreshing doesn't re-verify
  return Astro.redirect("/dashboard");
}

// Fetch the user's plan requests
let requests = await db.query.planRequests.findMany({
  where: eq(dbSchema.planRequests.userId, user.id),
  orderBy: [desc(dbSchema.planRequests.createdAt)],
});

// Sweep: check any "pending_payment" requests and verify with Stripe
const pendingRequests = requests.filter(r => r.status === "pending_payment");
if (pendingRequests.length > 0) {
  try {
    const Stripe = (await import("stripe")).default;
    const stripe = new Stripe(env.STRIPE_SECRET_KEY, { apiVersion: "2024-04-10" as any });
    
    for (const req of pendingRequests) {
      let isPaid = false;
      
      if (req.stripeSessionId) {
        // Direct lookup by session ID
        const cs = await stripe.checkout.sessions.retrieve(req.stripeSessionId);
        isPaid = cs.payment_status === "paid";
      } else {
        // Fallback: search recent checkout sessions for this request's metadata
        const sessions = await stripe.checkout.sessions.list({ limit: 20 });
        const match = sessions.data.find(
          s => s.metadata?.requestId === req.id && s.payment_status === "paid"
        );
        if (match) {
          isPaid = true;
          req.stripeSessionId = match.id;
        }
      }
      
      if (isPaid) {
        await db.update(dbSchema.planRequests)
          .set({ status: "paid", stripeSessionId: req.stripeSessionId || undefined, updatedAt: new Date() })
          .where(eq(dbSchema.planRequests.id, req.id));
      }
    }
    // Re-fetch after updates
    requests = await db.query.planRequests.findMany({
      where: eq(dbSchema.planRequests.userId, user.id),
      orderBy: [desc(dbSchema.planRequests.createdAt)],
    });
  } catch (err) {
    console.error("Stripe sweep error:", err);
  }
}

// A helper for status badges
const getStatusBadge = (status: string) => {
  switch (status) {
    case 'pending_payment': return { label: 'Pending Payment', color: '#ff4d4f' };
    case 'paid': return { label: 'In Progress (72-96 hrs)', color: '#f7c800' };
    case 'delivered': return { label: 'Delivered', color: '#52c41a' };
    default: return { label: status, color: '#888' };
  }
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — BuffBook</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --gold: #f7c800;
        --bg: #080808;
        --bg-card: #111111;
        --border: #222222;
        --text: #e8e8e8;
        --text-muted: #888888;
        --radius: 8px;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: "Inter", sans-serif;
        margin: 0; padding: 0;
      }
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        height: 60px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-card);
      }
      .nav-logo {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.4rem;
        color: var(--gold);
        text-decoration: none;
      }
      .container {
        max-width: 1000px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }
      h1 {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      p.subtitle {
        color: var(--text-muted);
        margin-bottom: 2rem;
      }
      
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
      }
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .card-title {
        font-weight: 600;
        font-size: 1.1rem;
      }
      .badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        color: #000;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .card-date {
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .btn {
        background: var(--border);
        color: var(--text);
        border: none;
        padding: 0.6rem;
        border-radius: 4px;
        text-align: center;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: background 0.2s;
        cursor: pointer;
      }
      .btn:hover { background: #333; }
      .btn-primary {
        background: var(--gold);
        color: #000;
      }
      .btn-primary:hover { background: #ffe033; }
      
      .empty-state {
        text-align: center;
        padding: 4rem;
        border: 1px dashed var(--border);
        border-radius: var(--radius);
        color: var(--text-muted);
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-logo">BuffBook</a>
      <div style="font-size: 0.9rem; color: var(--text-muted);">
        {user.email}
      </div>
    </nav>
    
    <div class="container">
      <h1>Your Dashboard</h1>
      <p class="subtitle">Manage your custom gym plans here.</p>
      
      {requests.length === 0 ? (
        <div class="empty-state">
          <p>You haven't requested any custom plans yet.</p>
          <br/>
          <a href="/custom-plans/apply" class="btn btn-primary" style="display:inline-block; padding:0.8rem 1.5rem;">Apply Now</a>
        </div>
      ) : (
        <div class="grid">
          {requests.map((req) => {
            const status = getStatusBadge(req.status);
            return (
              <div class="card">
                <div class="card-header">
                  <div class="card-title">Hypertrophy Plan</div>
                  <div class="badge" style={`background: ${status.color};`}>{status.label}</div>
                </div>
                <div class="card-date">Requested: {new Date(req.createdAt).toLocaleDateString()}</div>
                
                {req.status === 'pending_payment' && (
                  <p style="font-size: 0.85rem; color: var(--text-muted);">Your checkout was interrupted. Contact support to resume.</p>
                )}
                {req.status === 'paid' && (
                  <p style="font-size: 0.85rem; color: var(--text-muted);">Your plan is currently being crafted. You will be notified when it's ready.</p>
                )}
                {req.status === 'delivered' && (
                  <a href={`/api/download/${req.id}`} target="_blank" class="btn btn-primary">Download PDF</a>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  </body>
</html>
