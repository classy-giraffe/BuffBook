---
import BaseLayout from "@layouts/BaseLayout.astro";
import Topbar from "../components/Topbar.astro";

interface Props {
  title?: string;
  description?: string;
  user?: import("better-auth").User;
}

const {
  title = "Dashboard — BuffBook",
  description = "Manage your custom training plans and account settings on BuffBook.",
  user,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    {Astro.locals.csrfToken && <meta name="csrf-token" content={Astro.locals.csrfToken} />}
  </Fragment>
  <div class="pointer-events-none fixed inset-0 -z-10" style="background: radial-gradient(ellipse 70% 60% at 50% 40%, hsl(var(--primary) / 0.05) 0%, transparent 70%), radial-gradient(ellipse 40% 30% at 20% 80%, hsl(var(--primary) / 0.03) 0%, transparent 60%);"></div>
  <Topbar user={user} />
  <div class="max-w-5xl mx-auto px-6 py-12">
    <slot />
  </div>
</BaseLayout>
