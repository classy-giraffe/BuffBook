---
import { env } from "cloudflare:workers";
import DashboardLayout from "../../components/DashboardLayout.astro";
import { drizzle } from "drizzle-orm/d1";
import * as dbSchema from "../../db/schema";
import { eq, desc } from "drizzle-orm";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@components/ui/table";
import { Badge } from "@components/ui/badge";
import { Button } from "@components/ui/button";
import { Separator } from "@components/ui/separator";

export const prerender = false;

const { session, user } = Astro.locals;

if (!user) {
  return Astro.redirect("/login");
}

const db = drizzle(env.DB, { schema: dbSchema });

// If returning from Stripe Checkout, verify the payment and update DB
const sessionId = Astro.url.searchParams.get("session_id");
if (sessionId) {
  try {
    const Stripe = (await import("stripe")).default;
    const stripe = new Stripe(env.STRIPE_SECRET_KEY, {
      apiVersion: "2024-04-10" as any,
    });
    const checkoutSession = await stripe.checkout.sessions.retrieve(sessionId);

    if (
      checkoutSession.payment_status === "paid" &&
      checkoutSession.metadata?.requestId
    ) {
      await db
        .update(dbSchema.planRequests)
        .set({
          status: "paid",
          stripeSessionId: sessionId,
          updatedAt: new Date(),
        })
        .where(
          eq(dbSchema.planRequests.id, checkoutSession.metadata.requestId),
        );
    }
  } catch (err) {
    console.error("Stripe session verification error:", err);
  }
  // Redirect to clean URL (remove query param) so refreshing doesn't re-verify
  return Astro.redirect("/dashboard");
}

// Fetch the user's plan requests
let requests = await db.query.planRequests.findMany({
  where: eq(dbSchema.planRequests.userId, user.id),
  orderBy: [desc(dbSchema.planRequests.createdAt)],
});

// Sweep: check any "pending_payment" requests and verify with Stripe
const pendingRequests = requests.filter((r) => r.status === "pending_payment");
if (pendingRequests.length > 0) {
  try {
    const Stripe = (await import("stripe")).default;
    const stripe = new Stripe(env.STRIPE_SECRET_KEY, {
      apiVersion: "2024-04-10" as any,
    });

    for (const req of pendingRequests) {
      let isPaid = false;

      if (req.stripeSessionId) {
        // Direct lookup by session ID
        const cs = await stripe.checkout.sessions.retrieve(req.stripeSessionId);
        isPaid = cs.payment_status === "paid";
      } else {
        // Fallback: search recent checkout sessions for this request's metadata
        const sessions = await stripe.checkout.sessions.list({ limit: 20 });
        const match = sessions.data.find(
          (s) =>
            s.metadata?.requestId === req.id && s.payment_status === "paid",
        );
        if (match) {
          isPaid = true;
          req.stripeSessionId = match.id;
        }
      }

      if (isPaid) {
        await db
          .update(dbSchema.planRequests)
          .set({
            status: "paid",
            stripeSessionId: req.stripeSessionId || undefined,
            updatedAt: new Date(),
          })
          .where(eq(dbSchema.planRequests.id, req.id));
      }
    }
    // Re-fetch after updates
    requests = await db.query.planRequests.findMany({
      where: eq(dbSchema.planRequests.userId, user.id),
      orderBy: [desc(dbSchema.planRequests.createdAt)],
    });
  } catch (err) {
    console.error("Stripe sweep error:", err);
  }
}

// A helper for status badges
const getStatusBadge = (status: string) => {
  switch (status) {
    case "pending_payment":
      return {
        label: "Pending Payment",
        variant: "destructive",
        className: "",
      };
    case "paid":
      return {
        label: "In Progress (72-96 hrs)",
        variant: "default",
        className: "bg-amber-500 hover:bg-amber-600 text-amber-50",
      };
    case "delivered":
      return {
        label: "Delivered",
        variant: "default",
        className: "bg-green-600 hover:bg-green-700 text-green-50",
      };
    default:
      return { label: status, variant: "secondary", className: "" };
  }
};
---

<DashboardLayout title="Dashboard - BuffBook" user={user}>
  <div class="max-w-6xl mx-auto space-y-8">
    <!-- Greeting -->
    <div
      class="flex flex-col sm:flex-row sm:items-center justify-between gap-4"
    >
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">
          Welcome back{user.name ? `, ${user.name.split(" ")[0]}` : ""}.
        </h1>
        <p class="text-muted-foreground mt-1">
          Manage and track your custom gym plans.
        </p>
      </div>
      <a href="/custom-plans/apply">
        <Button className="font-bold">Request New Plan</Button>
      </a>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="rounded-xl border bg-card p-5 flex flex-col gap-1">
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-muted-foreground">Total Plans</span>
        <span class="text-3xl font-black text-foreground tracking-tight">{requests.length}</span>
      </div>
      <div class="rounded-xl border bg-card p-5 flex flex-col gap-1">
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-muted-foreground">In Progress</span>
        <span class="text-3xl font-black text-primary tracking-tight">{requests.filter(r => r.status === "paid").length}</span>
      </div>
      <div class="rounded-xl border bg-card p-5 flex flex-col gap-1">
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-muted-foreground">Delivered</span>
        <span class="text-3xl font-black tracking-tight" style="color: hsl(142 71% 45%)">{requests.filter(r => r.status === "delivered").length}</span>
      </div>
    </div>

    <Separator className="opacity-50" />

    <div class="border rounded-xl bg-card/50 backdrop-blur-sm shadow-sm overflow-hidden">
      <Table>
        <TableHeader>
          <TableRow>
            <TableHead>Date Requested</TableHead>
            <TableHead>Plan Details</TableHead>
            <TableHead>Status</TableHead>
            <TableHead className="text-right">Action</TableHead>
          </TableRow>
        </TableHeader>
        <TableBody>
          {
            requests.length === 0 ? (
              <TableRow>
                <TableCell
                  colSpan={4}
                  className="h-56 text-center text-muted-foreground"
                >
                  <div class="flex flex-col items-center gap-4">
                    <div class="h-16 w-16 rounded-2xl bg-muted flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/60"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                    </div>
                    <div>
                      <p class="font-semibold text-foreground mb-1">No plans yet</p>
                      <p class="text-sm mb-4">Get a hand-crafted hypertrophy plan built just for you.</p>
                    </div>
                    <a href="/custom-plans/apply">
                      <Button size="sm" className="font-bold">
                        Get Your First Plan
                      </Button>
                    </a>
                  </div>
                </TableCell>
              </TableRow>
            ) : (
              requests.map((req) => {
                const status = getStatusBadge(req.status);
                let subtext = "";
                if (req.status === "pending_payment")
                  subtext = "Checkout interrupted. Contact support.";
                else if (req.status === "paid")
                  subtext = "Being crafted by our coaches.";
                else if (req.status === "delivered")
                  subtext = "Ready for download.";

                return (
                  <TableRow>
                    <TableCell className="font-medium text-muted-foreground whitespace-nowrap">
                      {new Date(req.createdAt).toLocaleDateString(undefined, {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </TableCell>
                    <TableCell>
                      <div class="font-semibold text-foreground">
                        Hypertrophy Plan
                      </div>
                      <div class="text-xs text-muted-foreground">{subtext}</div>
                    </TableCell>
                    <TableCell>
                      <Badge
                        variant={status.variant as any}
                        className={`rounded-sm whitespace-nowrap ${status.className}`}
                      >
                        {status.label}
                      </Badge>
                    </TableCell>
                    <TableCell className="text-right">
                      {req.status === "delivered" ? (
                        <a href={`/api/download/${req.id}`} target="_blank">
                          <Button variant="outline" size="sm">
                            Download PDF
                          </Button>
                        </a>
                      ) : (
                        <Button variant="outline" size="sm" disabled>
                          Download PDF
                        </Button>
                      )}
                    </TableCell>
                  </TableRow>
                );
              })
            )
          }
        </TableBody>
      </Table>
    </div>
  </div>
</DashboardLayout>
