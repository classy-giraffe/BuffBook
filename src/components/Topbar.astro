---
import Logo from "./shared/Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { UserNav } from "./UserNav";

interface Props {
  user?: import("better-auth").User;
}

const { user } = Astro.props;
---

<nav
  class="sticky top-0 z-50 flex h-16 items-center justify-between border-b bg-background/80 px-8 backdrop-blur-md"
>
  <div class="flex items-center gap-2">
    <Logo size="sm" href="" />
    <a href="/" class="font-bold tracking-tight">BuffBook</a>
  </div>
  <div class="flex items-center gap-6 text-sm text-muted-foreground">
    <ThemeToggle />
    {user && <UserNav client:load user={user} />}
  </div>
</nav>
