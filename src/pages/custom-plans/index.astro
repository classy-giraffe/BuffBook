---
import { Button } from "@components/ui/button";
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
} from "@components/ui/card";
import { Separator } from "@components/ui/separator";
import { FaqAccordion } from "../../components/FaqAccordion";
import "../../styles/global.css";

const faqs = [
  {
    question: "How long does it take to receive my plan?",
    answer: "Every plan is built from scratch. Once you submit your comprehensive assessment, it typically takes 72-96 hours for me to analyze your data and craft the perfect mesocycle."
  },
  {
    question: "Do I need a fully equipped gym?",
    answer: "Not necessarily, but you need enough equipment to progressively overload. During the assessment, you'll list the equipment you have access to, and I will select exercises that fit your environment."
  },
  {
    question: "Is this a recurring subscription?",
    answer: "No. This is a one-time fee for a custom mesocycle. You can run the mesocycle for 4-8 weeks, deload, and rerun it with slightly increased weights. You only pay again if your goals or schedule drastically change and you want a completely new program."
  },
  {
    question: "What if I don't know my 1-rep maxes?",
    answer: "That's perfectly fine. The program focuses on RPE (Rate of Perceived Exertion) and RIR (Reps in Reserve) rather than strict percentages of a 1RM, which is more effective for hypertrophy anyway."
  }
];
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Custom Gym Plans - BuffBook</title>
    <meta
      name="description"
      content="Get a handcrafted, science-based gym plan tailored exactly to your goals, body, and experience level."
    />
    <script is:inline>
      document.documentElement.dataset.theme = 'dark';
    </script>
  </head>
  <body
    class="bg-background text-foreground font-sans antialiased relative min-h-screen flex flex-col"
  >
    <nav
      class="fixed top-0 left-0 right-0 z-50 flex h-16 items-center justify-between border-b bg-background/80 px-6 md:px-12 backdrop-blur-md"
    >
      <a
        href="/"
        class="flex items-center gap-2 font-bold tracking-tight text-xl text-primary hover:opacity-80 transition-opacity"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-6 w-6 fill-primary"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z"
          ></path>
        </svg>
        BuffBook
      </a>
      <a href="/">
        <Button size="sm" variant="outline" className="font-bold"
          >Back to Book</Button
        >
      </a>
    </nav>

    <main class="flex-1">
      <section
        class="relative flex min-h-[85vh] flex-col items-center justify-center overflow-hidden px-6 text-center pt-24 pb-16"
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10"
          style="background: radial-gradient(ellipse 70% 60% at 50% 40%, hsl(var(--primary) / 0.07) 0%, transparent 70%);"
        >
        </div>

        <div
          class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary mb-6"
        >
          <div class="h-px w-8 bg-primary/50"></div>
          Personalized Programming
          <div class="h-px w-8 bg-primary/50"></div>
        </div>

        <h1
          class="max-w-4xl text-5xl sm:text-7xl font-black tracking-tighter leading-[0.95] text-foreground mb-6"
        >
          Hand-crafted <span class="text-primary">Just For You.</span>
        </h1>

        <p
          class="max-w-2xl text-lg sm:text-xl text-muted-foreground mb-10 leading-relaxed"
        >
          No AI. No cookie-cutter templates. You fill out a comprehensive
          assessment, and I personally build your ideal hypertrophy plan from
          scratch in 72-96 hours.
        </p>

        <a href="/custom-plans/apply">
          <Button
            size="lg"
            className="h-14 px-8 text-base font-bold shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-shadow"
          >
            Get Your Plan - 30 EUR
          </Button>
        </a>
      </section>

      <section class="max-w-3xl mx-auto px-6 pb-24">
        <h2 class="text-3xl font-black tracking-tight text-foreground mb-10 text-center">Here is exactly what you get:</h2>
        
        <div class="space-y-12">
          <div class="flex flex-col sm:flex-row gap-6 sm:items-start">
            <div class="h-12 w-12 shrink-0 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold text-xl shadow-sm">1</div>
            <div>
              <h3 class="text-2xl font-black text-foreground mb-3">A Fully Customized Mesocycle</h3>
              <p class="text-muted-foreground leading-relaxed text-lg">
                A training program built specifically around your individual biomechanics, goals, and training history. You tell me what you want to achieve, and I build the exact roadmap to get you there without any guesswork.
              </p>
            </div>
          </div>
          
          <Separator className="opacity-30" />

          <div class="flex flex-col sm:flex-row gap-6 sm:items-start">
            <div class="h-12 w-12 shrink-0 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold text-xl shadow-sm">2</div>
            <div>
              <h3 class="text-2xl font-black text-foreground mb-3">Science-Backed Progression</h3>
              <p class="text-muted-foreground leading-relaxed text-lg">
                Your sets, reps, and progression schemes are mathematically matched to your recovery capacity. Using the peer-reviewed principles outlined in the BuffBook, I ensure you apply the exact amount of volume needed to grow - no more, no less.
              </p>
            </div>
          </div>

          <Separator className="opacity-30" />

          <div class="flex flex-col sm:flex-row gap-6 sm:items-start">
            <div class="h-12 w-12 shrink-0 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold text-xl shadow-sm">3</div>
            <div>
              <h3 class="text-2xl font-black text-foreground mb-3">Personalized Exercise Selection</h3>
              <p class="text-muted-foreground leading-relaxed text-lg">
                Not everyone is built to barbell squat or bench press. I personally review your past injuries, weak points, and available equipment to select exercises that are highly stimulating and safe for your specific leverages.
              </p>
            </div>
          </div>

          <Separator className="opacity-30" />

          <div class="flex flex-col sm:flex-row gap-6 sm:items-start">
            <div class="h-12 w-12 shrink-0 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold text-xl shadow-sm">4</div>
            <div>
              <h3 class="text-2xl font-black text-foreground mb-3">Detailed Execution Guide</h3>
              <p class="text-muted-foreground leading-relaxed text-lg">
                You won't just get a confusing spreadsheet. You'll receive a detailed PDF breakdown with specific form cues for each exercise, warm-up strategies, and exact instructions on how to log your progression accurately.
              </p>
            </div>
          </div>
        </div>
      </section>

      <Separator className="max-w-4xl mx-auto opacity-50" />
      
      <section class="max-w-3xl mx-auto px-6 py-24">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-black tracking-tight text-foreground">Frequently Asked Questions</h2>
          <p class="text-muted-foreground mt-2">Everything you need to know before applying.</p>
        </div>
        <FaqAccordion client:visible items={faqs} />
      </section>
    </main>
  </body>
</html>
