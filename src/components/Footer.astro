---
import Logo from "./shared/Logo.astro";
---

<footer class="relative mt-auto">
  <div class="h-px w-full bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

  <div class="py-16 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-2 w-fit">
          <Logo size="sm" href="" />
          <a href="/" class="font-bold tracking-tight text-xl text-primary hover:opacity-80 transition-opacity">BuffBook</a>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-xs">
          A free, peer-reviewed guide to the science of muscle hypertrophy. Open-source, forever.
        </p>
      </div>

      <!-- Col 2: Navigation -->
      <div class="flex flex-col gap-3">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground mb-1">Navigate</span>
        <a href="/chapter0/state-of-industry/" class="text-sm text-muted-foreground hover:text-foreground transition-colors w-fit">Start Reading</a>
        <a href="/custom-plans" class="text-sm text-muted-foreground hover:text-foreground transition-colors w-fit">Custom Plans</a>
        <a href="/contribute" class="text-sm text-muted-foreground hover:text-foreground transition-colors w-fit">Contribute</a>
        <a href="https://github.com/classy-giraffe/BuffBook" target="_blank" rel="noopener" class="text-sm text-muted-foreground hover:text-foreground transition-colors w-fit">GitHub</a>
      </div>

      <!-- Col 3: Legal + Credit -->
      <div class="flex flex-col gap-3">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground mb-1">Legal</span>
        <a href="/privacy" class="text-sm text-muted-foreground hover:text-foreground transition-colors w-fit">Privacy Policy</a>
        <a href="/terms" class="text-sm text-muted-foreground hover:text-foreground transition-colors w-fit">Terms of Service</a>
        <div class="mt-auto pt-4">
          <span class="text-xs text-muted-foreground/70">Built with love by classy-giraffe</span>
        </div>
      </div>
    </div>
  </div>
</footer>
