---
import { env } from "cloudflare:workers";
import { Button } from "@components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@components/ui/card";
import BaseLayout from "@layouts/BaseLayout.astro";

export const prerender = false;

let paymentStatus: "paid" | "processing" | "failed" | "verifying" = "verifying";
let requestId: string | null = null;

const sessionId = Astro.url.searchParams.get("session_id");

if (sessionId) {
  try {
    const Stripe = (await import("stripe")).default;
    const stripe = new Stripe(env.STRIPE_SECRET_KEY);
    const checkoutSession = await stripe.checkout.sessions.retrieve(sessionId);

    paymentStatus = checkoutSession.payment_status === "paid" ? "paid" : "processing";

    if (checkoutSession.payment_status === "paid" && checkoutSession.metadata?.requestId) {
      requestId = checkoutSession.metadata.requestId;
      const { getDb } = await import("@lib/db");
      const { planRequests } = await import("@db/schema");
      const { eq, and } = await import("drizzle-orm");
      const db = getDb(env);

      const [existing] = await db.select({ id: planRequests.id })
        .from(planRequests)
        .where(eq(planRequests.id, requestId));

      if (existing) {
        await db.update(planRequests)
          .set({ status: "paid", stripeSessionId: sessionId, updatedAt: new Date() })
          .where(and(eq(planRequests.id, requestId), eq(planRequests.status, "pending_payment")));
      }
    }
  } catch (err) {
    console.error("Stripe verify error:", err);
    paymentStatus = "failed";
  }
}
---

<BaseLayout title="Payment Confirmation - BuffBook" description="Your payment for a custom BuffBook training plan is being processed." bodyClass="flex items-center justify-center p-6">
  <div class="w-full max-w-md mx-auto">
    <Card className="border-primary/20 shadow-2xl bg-card/50 backdrop-blur-xl text-center">
      <CardHeader>
        <CardTitle className="text-2xl font-bold">
          {paymentStatus === "paid" ? "Payment Successful!" : paymentStatus === "processing" ? "Processing..." : paymentStatus === "failed" ? "Something went wrong" : "Verifying..."}
        </CardTitle>
        <CardDescription>
          {paymentStatus === "paid" ? "Your payment has been confirmed." : paymentStatus === "processing" ? "Your payment is being processed." : paymentStatus === "failed" ? "There was an error verifying your payment. Please check your dashboard." : "Checking your payment status..."}
        </CardDescription>
      </CardHeader>
      <CardContent className="space-y-6">
        <div class="text-lg font-medium text-muted-foreground leading-relaxed">
          {paymentStatus === "paid" && requestId && (
            <p>We'll prepare your custom hypertrophy plan within 72-96 hours. You'll be able to download it from your dashboard once it's ready.</p>
          )}
          {paymentStatus === "paid" && !requestId && (
            <p>Thank you for your purchase. You can track your plan status from your dashboard.</p>
          )}
          {paymentStatus === "verifying" && (
            <p>No session ID was provided. If you've just paid, check your dashboard for your plan status.</p>
          )}
        </div>

        <div class="flex flex-col gap-3">
          <a href="/dashboard" class="w-full">
            <Button className="w-full h-11 text-base font-bold">Go to Dashboard</Button>
          </a>
          <a href="/" class="w-full">
            <Button variant="outline" className="w-full h-11 text-base font-semibold">Back to BuffBook</Button>
          </a>
        </div>
      </CardContent>
    </Card>
  </div>
</BaseLayout>
