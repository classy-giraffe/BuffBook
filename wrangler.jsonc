{
	"compatibility_date": "2026-05-30",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"name": "buffbook",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"vars": {
		"BETTER_AUTH_URL": "https://buffbook.org"
	},
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "3761ae40cb1240088dcfefeee05115b2"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "buffbook_db",
			"database_id": "79f3f5ef-dfe5-4ba0-80ab-f83281516a78",
			"migrations_dir": "drizzle"
		}
	],
	"r2_buckets": [
		{
			"binding": "PLANS_BUCKET",
			"bucket_name": "buffbook-plans"
		}
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	}
}