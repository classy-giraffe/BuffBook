---
interface Props {
  user?: any;
}

const { user } = Astro.props;
---

<nav class="sticky top-0 z-50 flex h-16 items-center justify-between border-b bg-background/80 px-8 backdrop-blur-md">
  <a href="/" class="flex items-center gap-2 font-semibold text-lg hover:opacity-80 transition-opacity">
    <svg viewBox="0 0 24 24" class="h-6 w-6 fill-primary" xmlns="http://www.w3.org/2000/svg">
      <path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z"></path>
    </svg>
    <span class="font-bold tracking-tight">BuffBook</span>
  </a>
  <div class="flex items-center gap-6 text-sm text-muted-foreground">
    {user ? (
      <>
        <span>{user.email}</span>
        <button id="signout-btn" class="font-medium text-foreground hover:text-primary transition-colors">Sign Out</button>
      </>
    ) : null}
  </div>
</nav>

<script>
  import { authClient } from "../lib/auth-client";
  
  const signoutBtn = document.getElementById("signout-btn");
  if (signoutBtn) {
    signoutBtn.addEventListener("click", async () => {
      await authClient.signOut();
      window.location.href = "/login";
    });
  }
</script>
